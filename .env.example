TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=

# Local storage for downloaded Telegram media and generated request payloads.
SHIPYARD_STORAGE_DIR=data

# OpenAI models used in step 1.
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_PLANNING_MODEL=gpt-4o-mini

# How long a photo should be treated as the pending sketch for a chat.
PENDING_PHOTO_TTL_MINUTES=30

# Telegram network timeout in seconds. Raise this if Telegram is slow from your network.
TELEGRAM_NETWORK_TIMEOUT_SECONDS=30

# Step 3 worktrees are created here.
SHIPYARD_WORKTREE_ROOT=/tmp/shipyard

# Step 6 dashboard server.
SHIPYARD_ENABLE_SERVER=true
SHIPYARD_SERVER_HOST=127.0.0.1
SHIPYARD_SERVER_PORT=5050
